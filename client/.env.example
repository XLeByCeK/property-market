# ============================================================
#  ШАБЛОН переменных окружения для ФРОНТЕНДА (client, Next.js)
#  Локально скопируйте в .env.local и подставьте значения.
#  На Vercel задавайте эти переменные в Settings → Environment Variables.
#
#  ВАЖНО: переменные с префиксом NEXT_PUBLIC_ попадают в браузер,
#  поэтому СЕКРЕТЫ сюда класть нельзя — только публичные адреса/ключи карт.
# ============================================================

# Адрес бэкенд-API (обязательно с суффиксом /api).
# Локально: http://localhost:3001/api
# В проде:  https://your-api.onrender.com/api
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# Публичный базовый URL хранилища фото (тот же бакет, что на бэкенде)
NEXT_PUBLIC_YANDEX_STORAGE_URL="https://storage.yandexcloud.net/propertymarket"

# Ключ Яндекс.Карт (публичный, ограничьте его по домену в кабинете Яндекса)
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""
