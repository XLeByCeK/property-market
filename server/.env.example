# ============================================================
#  ШАБЛОН переменных окружения для БЭКЕНДА (server)
#  Скопируйте этот файл в .env и подставьте реальные значения.
#  Реальный .env в git НЕ попадает (см. .gitignore).
#  На хостинге (Render/Railway) задавайте эти же переменные
#  в разделе Environment Variables, а не в файле.
# ============================================================

# --- База данных PostgreSQL ---
# Локально: postgresql://USER:PASSWORD@localhost:5432/propertydb?schema=public
# В проде: строка подключения от вашего облачного Postgres (Neon/Supabase/Render)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/propertydb?schema=public"

# --- Авторизация (JWT) ---
# В проде ОБЯЗАТЕЛЬНО длинная случайная строка, а не "password"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- Сервер ---
PORT=3001
NODE_ENV=development
# Адреса фронтенда, которым разрешён доступ (через запятую).
# В проде укажите домен с Vercel, напр.: https://your-app.vercel.app
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# --- OpenAI (AI-поиск) ---
OPENAI_API_KEY="sk-..."

# --- Yandex Object Storage (хранилище фото, S3-совместимое) ---
YANDEX_STORAGE_ENDPOINT="https://storage.yandexcloud.net"
YANDEX_STORAGE_REGION="ru-central1"
YANDEX_STORAGE_BUCKET="propertymarket"
YANDEX_STORAGE_ACCESS_KEY_ID="your-access-key-id"
YANDEX_STORAGE_SECRET_ACCESS_KEY="your-secret-access-key"
YANDEX_STORAGE_PUBLIC_BASE_URL="https://storage.yandexcloud.net/propertymarket"
YANDEX_STORAGE_UPLOAD_PREFIX="property_images/uploads"
